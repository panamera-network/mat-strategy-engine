from pywebpush import webpush, WebPushException

def send_web_push(subscription_info, data):
    try:
        webpush(
            subscription_info=subscription_info,
            data=data,
            vapid_private_key="your-private-key",
            vapid_claims={"sub": "mailto:admin@yourdomain.com"}
        )
    except WebPushException as ex:
        print("Push failed:", repr(ex))

import requests

def send_fcm(token, title, body):
    headers = {
        "Authorization": "key=YOUR_SERVER_KEY",
        "Content-Type": "application/json"
    }
    payload = {
        "to": token,
        "notification": {
            "title": title,
            "body": body,
            "click_action": "OPEN_COCKPIT"
        },
        "data": { "symbol": "EURUSD", "recommendation": "Go" }
    }
    requests.post("https://fcm.googleapis.com/fcm/send", headers=headers, json=payload)
