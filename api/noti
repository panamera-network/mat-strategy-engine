def get_user_rules(user_id: str):
    # Query DB for all rules for this user
    return [
        # Example: push only for EURUSD critical
        {"channel": "push", "symbol": "EURUSD", "severity": "critical", "enabled": True},
        # Example: slack for all
        {"channel": "slack", "symbol": None, "severity": None, "enabled": True},
    ]

class NotificationRouter:
    def __init__(self, channels):
        self.channels = {ch.name: ch for ch in channels}

    def dispatch(self, event: dict, user_id: str):
        rules = get_user_rules(user_id)
        for rule in rules:
            if not rule["enabled"]:
                continue
            if rule["symbol"] and rule["symbol"] != event["symbol"]:
                continue
            if rule["mode"] and rule["mode"] != event["mode"]:
                continue
            if rule["severity"] and rule["severity"] != event["severity"]:
                continue
            # Send via matching channel
            self.channels[rule["channel"]].send(event, user_id)

from datetime import datetime, timedelta
from typing import List

class EscalationScheduler:
    def __init__(self, router, queue):
        self.router = router     # NotificationRouter with channel adapters
        self.queue = queue       # delayed task queue (e.g., APScheduler/RQ)

    def schedule_escalation(self, event: dict, user_id: str):
        rules = get_escalation_rules(user_id, event)  # filter by symbol/mode/severity
        # Step 0: immediate delivery (push) can be part of rules or baseline
        for rule in rules:
            if not rule.enabled: 
                continue
            run_at = datetime.utcnow() + timedelta(seconds=rule.delay_seconds)
            self.queue.enqueue_at(
                run_at, self._attempt_delivery, event, user_id, rule, attempt=0
            )

    def _attempt_delivery(self, event, user_id, rule, attempt):
        if is_acknowledged(user_id, event["event_id"]):
            return  # stop escalation
        # Respect DND if configured
        if in_dnd(user_id):
            # Option: reschedule at end of DND
            next_time = next_allowed_time(user_id)
            self.queue.enqueue_at(next_time, self._attempt_delivery, event, user_id, rule, attempt)
            return
        # Deliver via rule.channel
        self.router.channels[rule.channel].send(event, user_id)
        # Retries with backoff
        if attempt < rule.max_retries:
            backoff = rule.backoff_seconds * (2 ** attempt)  # exponential
            run_at = datetime.utcnow() + timedelta(seconds=backoff)
            self.queue.enqueue_at(run_at, self._attempt_delivery, event, user_id, rule, attempt + 1)
