class NotificationRouter:
    def __init__(self, channels):
        self.channels = {ch.name: ch for ch in channels}  # dict by channel name

    def dispatch(self, event: dict, user_id: str):
        prefs = get_user_preferences(user_id)  # query DB
        for channel_name, enabled in prefs.items():
            if enabled and channel_name in self.channels:
                self.channels[channel_name].send(event, user_id)

