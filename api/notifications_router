from fastapi import APIRouter
from typing import List
import json, uuid
from datetime import datetime

router = APIRouter()
clients = []
notification_history: List[dict] = []
notifications: List[dict] = []

class Notification(BaseModel):
    event_id: str
    timestamp: str
    symbol: str
    mode: str
    event_type: str
    title: str
    message: str
    recommendation: str
    unread: bool = True

@router.websocket("/ws")
async def websocket_endpoint(ws):
    await ws.accept()
    clients.append(ws)
    try:
        while True:
            await ws.receive_text()
    except:
        clients.remove(ws)

async def broadcast_notification(symbol, mode, event_type, message, recommendation="Watch"):
    event = {
        "event_id": str(uuid.uuid4()),
        "timestamp": datetime.utcnow().isoformat() + "Z",
        "symbol": symbol,
        "mode": mode,
        "event_type": event_type,
        "severity": "info",
        "title": f"{mode.capitalize()} {event_type.replace('_',' ').title()}",
        "message": message,
        "recommendation": recommendation,
        "source": "algo_engine_v1"
    }
    # Save to history
    notification_history.append(event)
    # Broadcast to live clients
    for ws in clients:
        await ws.send_text(json.dumps(event))

# REST endpoint to fetch past notifications
@router.get("/history")
async def get_notifications(limit: int = 50):
    return notification_history[-limit:]



@router.get("/history")
async def get_history(
    limit: int = 50,
    offset: int = 0,
    symbol: str = None,
    mode: str = None,
    severity: str = None,
    unread: bool = None
):
    query = notifications  # replace with DB query
    if symbol:
        query = [n for n in query if n["symbol"] == symbol]
    if mode:
        query = [n for n in query if n["mode"] == mode]
    if severity:
        query = [n for n in query if n["severity"] == severity]
    if unread is not None:
        query = [n for n in query if n["unread"] == unread]

    total = len(query)
    items = query[::-1][offset:offset+limit]  # newest first
    return {"items": items, "total": total, "limit": limit, "offset": offset}


@router.get("/{event_id}", response_model=Notification)
async def get_notification(event_id: str):
    return next(n for n in notifications if n["event_id"] == event_id)

@router.post("/{event_id}/ack")
async def mark_read(event_id: str):
    for n in notifications:
        if n["event_id"] == event_id:
            n["unread"] = False
            return {"status": "ok", "event_id": event_id, "unread": False}

@router.post("/ack-all")
async def mark_all_read():
    count = 0
    for n in notifications:
        if n["unread"]:
            n["unread"] = False
            count += 1
    return {"status": "ok", "updated": count}

